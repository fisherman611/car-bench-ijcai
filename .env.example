ANTHROPIC_API_KEY=
GEMINI_API_KEY=
LOGURU_LEVEL=DEBUG
LOG_FORMAT=text
OPENAI_API_KEY=
NVIDIA_NIM_API_KEY=
NVIDIA_NIM_API_BASE=https://integrate.api.nvidia.com/v1
USE_9ROUTER=true
NINE_ROUTER_API_BASE=http://localhost:20128/v1
NINE_ROUTER_API_KEY=
NINE_ROUTER_DISABLE_WSL_REMAP=false
NINE_ROUTER_MODEL=nvidia/openai/gpt-oss-120b
NINE_ROUTER_LITELLM_PROVIDER=nvidia_nim
AGENT_LLM=nvidia_nim/nvidia/openai/gpt-oss-120b
AGENT_TEMPERATURE=0.0
EVALUATOR_USER_MODEL=nvidia/openai/gpt-oss-120b
EVALUATOR_USER_PROVIDER=nvidia_nim
EVALUATOR_USER_THINKING=false
EVALUATOR_POLICY_EVALUATOR_MODEL=nvidia/openai/gpt-oss-120b
EVALUATOR_POLICY_EVALUATOR_PROVIDER=nvidia_nim
# For Codex Docker runs, prefer a dedicated authenticated home:
#   mkdir -p "$HOME/.codex-car-bench"
#   CODEX_HOME="$HOME/.codex-car-bench" codex login
# Then set an absolute host path here, for example:
#   CODEX_HOME_HOST=/Users/yourname/.codex-car-bench
CODEX_HOME_HOST=
CODEX_APP_SERVER_CMD=
CODEX_MODEL=gpt-5.3-codex-spark
CODEX_REASONING_EFFORT=medium
CODEX_PLANNER_MODEL=gpt-5.5
CODEX_EXECUTOR_MODEL=gpt-5.3-codex-spark
CODEX_PLANNER_REASONING_EFFORT=medium
CODEX_EXECUTOR_REASONING_EFFORT=medium
CODEX_TIMEOUT_SECONDS=180
CODEX_MALFORMED_RETRIES=1
